# Environment variables for BrandPulse AI
# Copy this to .env.local and add your API keys

# Required - AI Provider API Keys (at least one is required)
# Primary: NVIDIA (via OpenAI-compatible API at integrate.api.nvidia.com)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Backup: Groq (via OpenAI-compatible API)
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional - Rate Limiting Configuration
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_MS=60000

# Optional - Cache Configuration
# CACHE_TTL_MS=300000

# Logo.dev API - Brand logos on dashboard (publishable key, safe for client-side)
# Get your free key at: https://logo.dev
NEXT_PUBLIC_LOGO_DEV_TOKEN=your_logo_dev_publishable_key_here
